# ── Database (app connection — non-superuser, RLS applies) ──
# Docker: @postgres   Local: @localhost
DATABASE_URL=postgres://app_user:app_password@localhost:5432/yurdelo

# ── Database (migrations — superuser, bypasses RLS) ──────────
MIGRATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/yurdelo

# ── Database passwords (used by docker-compose.prod.yml) ─────
POSTGRES_PASSWORD=postgres

# ── Redis ─────────────────────────────────────────────
# Docker: redis   Local: localhost
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=change_me_32_chars_minimum_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── S3 (Selectel) ────────────────────────────────────
S3_ENDPOINT=https://s3.storage.selcloud.ru
S3_REGION=ru-1
S3_BUCKET=yurdelo-docs
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Email (UniSender) ────────────────────────────────
UNISENDER_API_KEY=
UNISENDER_FROM_EMAIL=noreply@yurdelo.ru

# ── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
