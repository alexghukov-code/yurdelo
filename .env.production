# ── Redis ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=6421ff7033baaec0a2890e03dca975e77759f6f8

# ── JWT ───────────────────────────────────────────────
JWT_SECRET=94cd32c20d271fe93da4e2e3fce84630cf209489c704a697eec2a02a359d205b
