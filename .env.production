# ── Database (app connection — non-superuser, RLS applies) ──
DATABASE_URL=postgres://app_user:29203f28eb2d4028704444ea4151d86a5a0e0df2@postgres:5432/yurdelo

# ── Database (migrations — superuser, bypasses RLS) ──────────
MIGRATION_DATABASE_URL=postgres://postgres:d3ee0209bafac695e648419b3905818de9810a9e@postgres:5432/yurdelo

# ── PostgreSQL container password (must match MIGRATION_DATABASE_URL) ──
