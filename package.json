{
  "name": "yurdelo",
  "version": "2.1.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "build:shared": "npm run build -w packages/shared",
    "build:backend": "npm run build -w packages/backend",
    "build:frontend": "npm run build -w packages/frontend",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "lint": "eslint packages/*/src/**/*.{ts,tsx}",
    "lint:fix": "eslint --fix packages/*/src/**/*.{ts,tsx}",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\"",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "npm run test -w packages/backend",
    "test:frontend": "npm run test -w packages/frontend",
    "typecheck": "npm run typecheck -w packages/shared && npm run typecheck -w packages/backend && npm run typecheck -w packages/frontend",
    "db:migrate": "npm run db:migrate -w packages/backend",
    "db:migrate:create": "npm run db:migrate:create -w packages/backend",
    "db:rollback": "npm run db:rollback -w packages/backend",
    "db:seed": "npm run db:seed -w packages/backend",
    "docker:up": "docker compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
