{
  "name": "@yurdelo/backend",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "node-pg-migrate up --database-url-var MIGRATION_DATABASE_URL --migrations-dir ../../db/migrations --migration-file-language sql --envPath ../../.env",
    "db:migrate:create": "node-pg-migrate create --migrations-dir ../../db/migrations --migration-file-language sql",
    "db:rollback": "node-pg-migrate down --database-url-var MIGRATION_DATABASE_URL --migrations-dir ../../db/migrations --migration-file-language sql --envPath ../../.env",
    "db:seed": "node-pg-migrate up --database-url-var MIGRATION_DATABASE_URL --migrations-dir ../../db/seeds --migration-file-language sql --migrations-table pgmigrations_seeds --envPath ../../.env"
  },
  "dependencies": {
    "@yurdelo/shared": "*",
    "express": "^5.0.0",
    "pg": "^8.12.0",
    "ioredis": "^5.4.0",
    "dotenv": "^16.4.0",
    "bullmq": "^5.12.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "cookie-parser": "^1.4.7",
    "jsonwebtoken": "^9.0.0",
    "otplib": "^12.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/cookie-parser": "^1.4.0",
    "@types/multer": "^1.4.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.0",
    "node-pg-migrate": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0"
  }
}
